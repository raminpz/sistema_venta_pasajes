APP_PORT=8080
APP_ENV=development

# Solo desarrollo frontend/local. En producción siempre false.
AUTH_DISABLED=false

# JWT HS256 secret (usar un valor robusto en producción)
JWT_SECRET=REEMPLAZAR_POR_UN_SECRETO_LARGO_Y_SEGURO

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=SISTEMA_PASAJES
DB_USER=root
DB_PASS=
DB_PARAMS=parseTime=true&loc=Local&charset=utf8mb4
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30

HTTP_READ_TIMEOUT=10
HTTP_WRITE_TIMEOUT=10

